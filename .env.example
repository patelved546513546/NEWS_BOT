# ==========================================
# Email Configuration (Gmail SMTP - FREE)
# ==========================================
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here
EMAIL_RECIPIENTS=your.email@gmail.com

# For multiple recipients (comma-separated):
# EMAIL_RECIPIENTS=email1@gmail.com,email2@gmail.com,email3@gmail.com

# Optional: Resend API (recommended on Render if SMTP is unreachable)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=News Bot <onboarding@resend.dev>

# ==========================================
# AI Configuration (Groq - FREE)
# ==========================================
GROQ_API_KEY=gsk_your_groq_api_key_here

# ==========================================
# Bot Configuration
# ==========================================
UPDATE_INTERVAL_MINUTES=15
MAX_NEWS_ARTICLES=5
DELIVERY_MODE=interval
DIGEST_SEND_TIME=20:00
DAILY_DIGEST_HOURS=24
DAILY_DIGEST_MAX_ARTICLES=40
TIMEZONE=Asia/Kolkata
PORT=8080
NEWS_CATEGORY=world

# DELIVERY_MODE options:
# interval   -> send alert every UPDATE_INTERVAL_MINUTES
# daily_pdf  -> send one PDF digest at DIGEST_SEND_TIME each day

# Supported categories:
# world, science, technology, politics, stock_market, stock_market_impact
# Note: stock_market and stock_market_impact are filtered for India and US markets only.

# ==========================================
# Optional: Telegram Bot (FREE UNLIMITED)
# ==========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ==========================================
# Optional: WhatsApp (CallMeBot - Unreliable)
# ==========================================
YOUR_WHATSAPP_NUMBER=919876543210
CALLMEBOT_API_KEY=your_callmebot_key